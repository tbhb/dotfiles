#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"

# ---------------------------------------------------------------------------
# Preflight: devcontainer CLI must be available
# ---------------------------------------------------------------------------
if ! command -v devcontainer &>/dev/null; then
  echo "ERROR: 'devcontainer' CLI not found."
  echo "Install it with: npm install -g @devcontainers/cli"
  exit 1
fi

# ---------------------------------------------------------------------------
# Build / start the devcontainer
# ---------------------------------------------------------------------------
up_args=(--workspace-folder "$REPO_ROOT")
if [[ "${REMOVE_EXISTING:-}" == "true" ]]; then
  up_args+=(--remove-existing-container)
fi

echo "==> Starting devcontainer…"
devcontainer up "${up_args[@]}"

# ---------------------------------------------------------------------------
# Run the test suite inside the container
# ---------------------------------------------------------------------------
echo "==> Running tests…"
rc=0
devcontainer exec --workspace-folder "$REPO_ROOT" \
  zsh -lic "source ~/dotfiles/script/test-dotfiles" || rc=$?

# ---------------------------------------------------------------------------
# Teardown (unless KEEP_CONTAINER=true)
# ---------------------------------------------------------------------------
if [[ "${KEEP_CONTAINER:-}" == "true" ]]; then
  echo "==> Keeping container (KEEP_CONTAINER=true)"
else
  echo "==> Removing container…"
  cid=$(docker ps -aq --filter "label=devcontainer.local_folder=$REPO_ROOT")
  if [[ -n "$cid" ]]; then
    docker rm -f "$cid" >/dev/null
  fi
fi

exit "$rc"
